# AWS Configuration
AWS_REGION=us-east-2
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID

# EKS Configuration
EKS_CLUSTER_NAME=observability-cluster
EKS_NODE_INSTANCE_TYPE=t3.medium
EKS_NODE_DESIRED_COUNT=3
EKS_NODE_MIN_COUNT=2
EKS_NODE_MAX_COUNT=5
EKS_ENABLE_SPOT=true

# VPC Configuration
VPC_CIDR=10.0.0.0/16

# Docker Registry
REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=observability123

# Monitoring Configuration
PROMETHEUS_STORAGE_SIZE=20Gi
TEMPO_STORAGE_SIZE=5Gi

# Load Tester Configuration
LOAD_TESTER_BASE_RPS=10
LOAD_TESTER_HEALTH_RATIO=0.7
LOAD_TESTER_SLOW_RATIO=0.2
LOAD_TESTER_ERROR_RATIO=0.1

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4317
OTEL_SERVICE_NAME=observability-portfolio
OTEL_TRACE_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp
